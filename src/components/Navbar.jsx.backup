import { useState } from "react";
import { Link, useLocation, useNavigate } from "react-router-dom";
import { Menu, X, ShoppingBag, ShoppingCart, User, LogOut, Shield } from "lucide-react";
import { useAuth } from "@/contexts/AuthContext";
import { useCart } from "@/contexts/CartContext";

const navLinks = [
  { to: "/", label: "Accueil" },
  { to: "/produits", label: "Produits" },
  { to: "/contact", label: "Contact" },
];

const Navbar = () => {
  const [open, setOpen] = useState(false);
  const location = useLocation();
  const navigate = useNavigate();
  const { user, isAdmin, signOut } = useAuth();
  const { itemCount } = useCart();

  const handleSignOut = async () => {
    await signOut();
    navigate("/");
    setOpen(false);
  };

  // Styles inline
  const navStyle = {
    position: "fixed",
    top: 0,
    left: 0,
    right: 0,
    zIndex: 50,
    backgroundColor: "white",
    boxShadow: "0 2px 8px rgba(0,0,0,0.1)",
    borderBottom: "1px solid #f3f4f6"
  };

  const containerStyle = {
    maxWidth: "1200px",
    margin: "0 auto",
    padding: "0 16px",
    display: "flex",
    alignItems: "center",
    justifyContent: "space-between",
    height: "80px"
  };

  const logoStyle = {
    display: "flex",
    alignItems: "center",
    gap: "12px",
    textDecoration: "none",
    color: "inherit",
    cursor: "pointer"
  };

  const logoBadgeStyle = {
    background: "linear-gradient(135deg, #b45309 0%, #f97316 100%)",
    padding: "10px",
    borderRadius: "8px",
    boxShadow: "0 4px 6px rgba(0,0,0,0.1)"
  };

  const logoTextStyle = {
    display: "flex",
    flexDirection: "column",
    gap: "0"
  };

  const logoMainStyle = {
    fontWeight: "bold",
    fontSize: "16px",
    background: "linear-gradient(90deg, #b45309 0%, #f97316 100%)",
    WebkitBackgroundClip: "text",
    WebkitTextFillColor: "transparent",
    lineHeight: "1.2"
  };

  const desktopNavStyle = {
    display: "none",
    "@media (min-width: 768px)": {
      display: "flex"
    },
    alignItems: "center",
    gap: "40px"
  };

  const rightSectionStyle = {
    display: "flex",
    alignItems: "center",
    gap: "20px"
  };

  const cartLinkStyle = {
    position: "relative",
    textDecoration: "none",
    color: "#374151",
    cursor: "pointer",
    padding: "8px",
    borderRadius: "6px",
    transition: "all 0.3s",
    display: "flex",
    alignItems: "center"
  };

  const cartBadgeStyle = {
    position: "absolute",
    top: "-4px",
    right: "-4px",
    backgroundColor: "#ef4444",
    color: "white",
    borderRadius: "50%",
    width: "20px",
    height: "20px",
    display: "flex",
    alignItems: "center",
    justifyContent: "center",
    fontSize: "11px",
    fontWeight: "bold",
    boxShadow: "0 2px 4px rgba(0,0,0,0.2)"
  };

  const mobileMenuButtonStyle = {
    display: "block",
    "@media (min-width: 768px)": {
      display: "none"
    },
    border: "none",
    background: "none",
    cursor: "pointer",
    color: "#374151",
    padding: "8px",
    borderRadius: "6px",
    transition: "all 0.3s"
  };

  const mobileMenuStyle = {
    display: open ? "block" : "none",
    "@media (min-width: 768px)": {
      display: "none"
    },
    backgroundColor: "white",
    borderTop: "1px solid #e5e7eb",
    boxShadow: "0 4px 6px rgba(0,0,0,0.1)"
  };

  return (
    <nav style={navStyle}>
      <div style={containerStyle}>
        {/* Logo */}
        <Link to="/" style={logoStyle}>
          <div style={logoBadgeStyle}>
            <ShoppingBag size={24} color="white" />
          </div>
          <div style={logoTextStyle}>
            <div style={logoMainStyle}>CHIC SENEGAL</div>
            <div style={{ fontSize: "12px", color: "#b45309", fontWeight: "600" }}>STYLE</div>
          </div>
        </Link>

        {/* Desktop Nav */}
        <div style={{ display: "flex", gap: "40px", alignItems: "center" }}>
          {navLinks.map((link) => (
            <Link
              key={link.to}
              to={link.to}
              style={{
                fontSize: "14px",
                fontWeight: "600",
                color: location.pathname === link.to ? "#ea580c" : "#374151",
                textDecoration: location.pathname === link.to ? "underline" : "none",
                transition: "all 0.3s"
              }}
            >{link.label}</Link>
          ))}
        </div>

        {/* Right Section */}
        <div style={rightSectionStyle}>
          <Link to="/panier" style={cartLinkStyle}>
            <ShoppingCart size={24} />
            {itemCount > 0 && <span style={cartBadgeStyle}>{itemCount}</span>}
          </Link>

          {user ? (
            <div style={{ display: "flex", gap: "12px", alignItems: "center" }}>
              {isAdmin && (
                <Link to="/admin" style={{ fontSize: "12px", fontWeight: "bold", color: "#ea580c", backgroundColor: "#fed7aa", padding: "6px 12px", borderRadius: "6px", textDecoration: "none", display: "flex", alignItems: "center", gap: "6px" }}>
                  <Shield size={14} /> Admin
                </Link>
              )}
              <button onClick={handleSignOut} style={{ border: "none", background: "none", cursor: "pointer", color: "#374151", display: "flex", alignItems: "center", padding: "8px" }}>
                <LogOut size={20} />
              </button>
            </div>
          ) : (
            <Link to="/auth" style={{ fontSize: "14px", fontWeight: "bold", color: "white", background: "linear-gradient(90deg, #b45309 0%, #f97316 100%)", padding: "10px 16px", borderRadius: "6px", textDecoration: "none", display: "flex", alignItems: "center", gap: "6px", transition: "all 0.3s" }}>
              <User size={16} /> Connexion
            </Link>
          )}

          {/* Mobile Menu Button */}
          <button onClick={() => setOpen(!open)} style={mobileMenuButtonStyle}>
            {open ? <X size={24} /> : <Menu size={24} />}
          </button>
        </div>
      </div>

      {/* Mobile Menu */}
      {open && (
        <div style={{ backgroundColor: "white", borderTop: "1px solid #e5e7eb", padding: "12px" }}>
          {navLinks.map((link) => (
            <Link 
              key={link.to} 
              to={link.to} 
              onClick={() => setOpen(false)} 
              style={{ display: "block", padding: "12px 8px", color: location.pathname === link.to ? "#ea580c" : "#374151", textDecoration: "none", fontWeight: "500", fontSize: "14px" }}
            >{link.label}</Link>
          ))}
          <div style={{ borderTop: "1px solid #e5e7eb", marginTop: "12px", paddingTop: "12px" }}>
            {user ? (
              <>
                {isAdmin && <Link to="/admin" onClick={() => setOpen(false)} style={{ display: "block", padding: "12px 8px", color: "#ea580c", textDecoration: "none", fontWeight: "500", fontSize: "14px" }}><Shield size={14} style={{ display: "inline", marginRight: "4px" }} /> Admin</Link>}
                <button onClick={handleSignOut} style={{ width: "100%", textAlign: "left", padding: "12px 8px", border: "none", background: "none", cursor: "pointer", color: "#374151", fontSize: "14px", fontWeight: "500" }}><LogOut size={14} style={{ display: "inline", marginRight: "4px" }} /> Déconnexion</button>
              </>
            ) : (
              <Link to="/auth" onClick={() => setOpen(false)} style={{ display: "block", textAlign: "center", padding: "10px", background: "linear-gradient(90deg, #b45309 0%, #f97316 100%)", color: "white", textDecoration: "none", fontWeight: "600", borderRadius: "6px" }}><User size={14} style={{ display: "inline", marginRight: "4px" }} /> Connexion</Link>
            )}
          </div>
        </div>
      )}
    </nav>
  );
};

export default Navbar;
